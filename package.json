{
  "name": "any-chat-completions-mcp",
  "version": "0.1.0",
  "description": "A Model Context Protocol server for integrating with any OpenAI SDK compatible Chat Completion API",
  "type": "module",
  "bin": {
    "any-chat-completions-mcp": "build/cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755'); require('fs').chmodSync('build/cli.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "clean": "rm -rf build",
    "npm-publish": "npm run clean && npm run build && npm publish --access=public",
    "start": "node build/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "dotenv": "^16.4.5",
    "openai": "^6.46.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "form-data": "^4.0.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cfdude/any-chat-completions-mcp.git"
  },
  "keywords": [
    "claude",
    "openai",
    "mcp",
    "model-context-protocol",
    "ai",
    "chat",
    "llm"
  ],
  "author": "PyroPrompts",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
